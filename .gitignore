# Terraform local working directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plan output
*.tfplan
*tfplan*

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files with secrets (keep sample files committed)
*.auto.tfvars
*.auto.tfvars.json
*.tfvars.json

# CLI config files (may contain credentials)
.terraformrc
terraform.rc

# Common local/editor artifacts
.DS_Store
.idea/
.vscode/
